{{ 'for-you-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign pill_blocks = section.blocks | where: "type", "pill"
  assign card_blocks = section.blocks | where: "type", "product_card"
-%}

<style>
  #fn-section-{{ section.id }} {
    --fn-max-width: {{ section.settings.container_max_width }}px;
    --fn-heading-size: {{ section.settings.heading_size }}px;

    --fn-pill-gap: {{ section.settings.pill_gap }}px;
    --fn-pill-bg: {{ section.settings.pill_inactive_bg }};
    --fn-pill-text: {{ section.settings.pill_inactive_text }};
    --fn-pill-font-size: {{ section.settings.pill_font_size }}px;
    --fn-pill-pad-v: {{ section.settings.pill_padding_v }}px;
    --fn-pill-pad-h: {{ section.settings.pill_padding_h }}px;
    --fn-pill-active-bg: {{ section.settings.pill_active_bg }};
    --fn-pill-active-text: {{ section.settings.pill_active_text_color }};
    --fn-pill-border: {{ section.settings.pill_border_color }};

    --fn-columns-mobile: {{ section.settings.columns_mobile }};
    --fn-columns-desktop: {{ section.settings.columns_desktop }};
    --fn-col-gap: {{ section.settings.grid_column_gap }}px;
    --fn-row-gap: {{ section.settings.grid_row_gap }}px;
    --fn-ratio: {{ section.settings.image_ratio }};
    --fn-radius: {{ section.settings.image_corner_radius }}px;
    --fn-card-border-width: {{ section.settings.card_border_width }}px;
    --fn-card-border-color: {{ section.settings.card_border_color }};

    --fn-title-font-size: {{ section.settings.title_font_size }}px;
    --fn-title-font-weight: {{ section.settings.title_font_weight }};
    --fn-price-font-size: {{ section.settings.price_font_size }}px;
    --fn-swatch-size: {{ section.settings.swatch_size }}px;
    --fn-swatch-ring: {{ section.settings.swatch_selected_ring_color }};
    --fn-heart-size: {{ section.settings.heart_icon_size }}px;
    --fn-heart-color: {{ section.settings.heart_color }};
    --fn-heart-active: {{ section.settings.heart_active_color }};

    --fn-badge-radius: {{ section.settings.badge_border_radius }}px;
    --fn-badge-font-size: {{ section.settings.badge_font_size }}px;
    --fn-badge-bg: {{ section.settings.badge_bg_color }};
    --fn-badge-text: {{ section.settings.badge_text_color }};

    --fn-price: {{ section.settings.price_color }};
    --fn-compare: {{ section.settings.compare_price_color }};
    --fn-title: {{ section.settings.title_color }};
    --fn-promo: {{ section.settings.promo_color }};

    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
    {%- if section.settings.show_section_background -%}
    background-color: {{ section.settings.section_background_color }};
    {%- endif -%}
  }

  {%- if section.settings.image_height_mobile > 0 -%}
  #fn-section-{{ section.id }} .fn-media {
    height: {{ section.settings.image_height_mobile }}px;
    aspect-ratio: unset;
  }
  {%- endif -%}

  {%- if section.settings.image_height_desktop > 0 -%}
  @media (min-width: 750px) {
    #fn-section-{{ section.id }} .fn-media {
      height: {{ section.settings.image_height_desktop }}px;
      aspect-ratio: unset;
    }
  }
  {%- endif -%}
</style>

<section class="fn-section" id="fn-section-{{ section.id }}">

  {%- if section.settings.show_heading and section.settings.heading != blank -%}
    <h2 class="fn-heading{% if section.settings.heading_alignment == 'center' %} fn-heading--center{% endif %}">
      {{ section.settings.heading }}
    </h2>
  {%- endif -%}

  {%- if section.settings.show_pills and pill_blocks.size > 0 -%}
  <div class="fn-filters">
    {%- for block in pill_blocks -%}
      <a
        href="{{ block.settings.link | default: '#' }}"
        class="fn-pill{% if block.settings.active %} active{% endif %}"
        {{ block.shopify_attributes }}
      >
        {%- if forloop.first and section.settings.show_pill_icon -%}
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l1.9 5.8L20 9.7l-5 3.6 1.9 6.1L12 16.1l-4.9 3.3 1.9-6.1-5-3.6 6.1-1.9L12 2z"/>
          </svg>
        {%- endif -%}
        {{ block.settings.label }}
      </a>
    {%- endfor -%}
  </div>
  {%- endif -%}

  <div class="fn-grid">
    {%- for block in card_blocks -%}
      {%- assign product = block.settings.product -%}

      {%- if product and product != blank -%}
        <article class="fn-card{% if section.settings.enable_card_shadow %} fn-card--shadow{% endif %}" {{ block.shopify_attributes }}>

          <a href="{{ product.url }}" class="fn-media">
            {%- if product.featured_image -%}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
                loading="lazy"
                width="600"
                height="800"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'fn-media-placeholder' }}
            {%- endif -%}

            {%- if block.settings.badge_text != blank -%}
              <span class="fn-badge{% if section.settings.badge_position == 'top-right' %} fn-badge--right{% endif %}">
                {{ block.settings.badge_text }}
              </span>
            {%- endif -%}
          </a>

          <div class="fn-info">
            <div class="fn-title-row">
              <a href="{{ product.url }}" class="fn-title">{{ product.title }}</a>

              {%- if section.settings.show_wishlist -%}
                <button
                  type="button"
                  class="fn-heart"
                  data-product-id="{{ product.id }}"
                  aria-label="Add {{ product.title | escape }} to wishlist"
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path d="M12 20.5s-7.5-4.6-10-9.4C0.3 7.8 2 4 5.6 4c2.1 0 3.6 1.2 4.4 2.6C10.8 5.2 12.3 4 14.4 4 18 4 19.7 7.8 18 11.1 15.5 15.9 12 20.5 12 20.5z"/>
                  </svg>
                </button>
              {%- endif -%}
            </div>

            <div class="fn-price-row">
              <span class="fn-price">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="fn-price-original">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>

            {%- if block.settings.promo_code != blank -%}
              <div class="fn-promo">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20 10.5V4h-6.5L3 14.5 9.5 21 20 10.5zM7.3 9a1.3 1.3 0 1 1 0-2.6A1.3 1.3 0 0 1 7.3 9z"/>
                </svg>
                With Code: {{ block.settings.promo_code }}
              </div>
            {%- endif -%}

            {%- if section.settings.show_swatches -%}
              {%- for option in product.options_with_values -%}
                {%- if option.name == 'Color' or option.name == 'Colour' -%}
                  <div class="fn-swatches">
                    {%- for value in option.values limit: 4 -%}
                      <span
                        class="fn-swatch{% if forloop.first %} selected{% endif %}"
                        data-color-name="{{ value | handle }}"
                        title="{{ value }}"
                      ></span>
                    {%- endfor -%}
                    {%- if option.values.size > 4 -%}
                      <span class="fn-swatch-more">+{{ option.values.size | minus: 4 }}</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          </div>
        </article>

      {%- elsif request.design_mode -%}
        <article class="fn-card fn-card--empty" {{ block.shopify_attributes }}>
          <div class="fn-media fn-media--empty">
            <p>Select a product for this card</p>
          </div>
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>

</section>

<script src="{{ 'for-you-grid.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "For You product grid",
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": false },
    { "type": "text", "id": "heading", "label": "Heading text", "default": "For You" },
    { "type": "range", "id": "heading_size", "label": "Heading font size", "min": 14, "max": 32, "step": 2, "unit": "px", "default": 20 },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },

    { "type": "header", "content": "Section container" },
    { "type": "checkbox", "id": "show_section_background", "label": "Enable section background color", "default": false },
    { "type": "color", "id": "section_background_color", "label": "Background color", "default": "#FFFFFF" },
    { "type": "range", "id": "container_max_width", "label": "Section max width", "min": 400, "max": 900, "step": 20, "unit": "px", "default": 600 },

    { "type": "header", "content": "Filter pills" },
    { "type": "checkbox", "id": "show_pills", "label": "Show filter pills", "default": true },
    { "type": "checkbox", "id": "show_pill_icon", "label": "Show icon on first pill", "default": true },
    { "type": "range", "id": "pill_gap", "label": "Space between pills", "min": 4, "max": 20, "step": 2, "unit": "px", "default": 10 },
    { "type": "range", "id": "pill_font_size", "label": "Pill font size", "min": 11, "max": 16, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "pill_padding_v", "label": "Pill vertical padding", "min": 4, "max": 16, "step": 1, "unit": "px", "default": 9 },
    { "type": "range", "id": "pill_padding_h", "label": "Pill horizontal padding", "min": 8, "max": 28, "step": 2, "unit": "px", "default": 18 },
    { "type": "color", "id": "pill_inactive_bg", "label": "Inactive pill background", "default": "#FFFFFF" },
    { "type": "color", "id": "pill_inactive_text", "label": "Inactive pill text", "default": "#1A1A1A" },
    { "type": "color", "id": "pill_active_bg", "label": "Active pill background", "default": "#111111" },
    { "type": "color", "id": "pill_active_text_color", "label": "Active pill text", "default": "#FFFFFF" },
    { "type": "color", "id": "pill_border_color", "label": "Pill border color", "default": "#111111" },

    { "type": "header", "content": "Grid layout" },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4"
    },
    { "type": "range", "id": "grid_column_gap", "label": "Space between columns", "min": 4, "max": 32, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "grid_row_gap", "label": "Space between rows", "min": 4, "max": 40, "step": 2, "unit": "px", "default": 18 },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image shape (used when height override below is 0)",
      "options": [
        { "value": "3/4", "label": "Portrait" },
        { "value": "1/1", "label": "Square" },
        { "value": "4/3", "label": "Landscape" }
      ],
      "default": "3/4"
    },
    { "type": "range", "id": "image_height_mobile", "label": "Image height on mobile (0 = auto, uses shape above)", "min": 0, "max": 700, "step": 10, "unit": "px", "default": 0 },
    { "type": "range", "id": "image_height_desktop", "label": "Image height on desktop (0 = auto, uses shape above)", "min": 0, "max": 800, "step": 10, "unit": "px", "default": 0 },
    { "type": "range", "id": "image_corner_radius", "label": "Image corner radius", "min": 0, "max": 24, "step": 2, "unit": "px", "default": 6 },
    { "type": "range", "id": "card_border_width", "label": "Image border width", "min": 0, "max": 4, "step": 1, "unit": "px", "default": 0 },
    { "type": "color", "id": "card_border_color", "label": "Image border color", "default": "#E5E5E5" },
    { "type": "checkbox", "id": "enable_card_shadow", "label": "Enable card shadow", "default": false },

    { "type": "header", "content": "Product info" },
    { "type": "checkbox", "id": "show_wishlist", "label": "Show wishlist heart icon", "default": true },
    { "type": "checkbox", "id": "show_swatches", "label": "Show color swatches", "default": true },
    { "type": "range", "id": "title_font_size", "label": "Title font size", "min": 11, "max": 18, "step": 1, "unit": "px", "default": 13 },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    },
    { "type": "range", "id": "price_font_size", "label": "Price font size", "min": 12, "max": 22, "step": 1, "unit": "px", "default": 15 },
    { "type": "range", "id": "swatch_size", "label": "Swatch size", "min": 12, "max": 28, "step": 2, "unit": "px", "default": 16 },
    { "type": "color", "id": "swatch_selected_ring_color", "label": "Selected swatch ring color", "default": "#111111" },
    { "type": "range", "id": "heart_icon_size", "label": "Wishlist icon size", "min": 14, "max": 30, "step": 2, "unit": "px", "default": 20 },

    { "type": "header", "content": "Badge" },
    {
      "type": "select",
      "id": "badge_position",
      "label": "Badge position",
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-right", "label": "Top right" }
      ],
      "default": "top-left"
    },
    { "type": "range", "id": "badge_border_radius", "label": "Badge corner radius", "min": 0, "max": 20, "step": 2, "unit": "px", "default": 4 },
    { "type": "range", "id": "badge_font_size", "label": "Badge font size", "min": 9, "max": 16, "step": 1, "unit": "px", "default": 11 },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "badge_bg_color", "label": "Badge background", "default": "#8A1A3D" },
    { "type": "color", "id": "badge_text_color", "label": "Badge text", "default": "#FFFFFF" },
    { "type": "color", "id": "title_color", "label": "Product title", "default": "#1A1A1A" },
    { "type": "color", "id": "price_color", "label": "Price", "default": "#8A1A3D" },
    { "type": "color", "id": "compare_price_color", "label": "Compare-at (strikethrough) price", "default": "#8C8C8C" },
    { "type": "color", "id": "promo_color", "label": "Promo code text", "default": "#8A1A3D" },
    { "type": "color", "id": "heart_color", "label": "Wishlist icon color", "default": "#222222" },
    { "type": "color", "id": "heart_active_color", "label": "Wishlist icon color (active)", "default": "#8A1A3D" },

    { "type": "header", "content": "Section spacing" },
    { "type": "range", "id": "section_padding_top", "label": "Top padding", "min": 0, "max": 60, "step": 4, "unit": "px", "default": 16 },
    { "type": "range", "id": "section_padding_bottom", "label": "Bottom padding", "min": 0, "max": 60, "step": 5, "unit": "px", "default": 30 }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Filter pill",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "New In" },
        { "type": "url", "id": "link", "label": "Link", "info": "Usually a collection page" },
        { "type": "checkbox", "id": "active", "label": "Active by default", "default": false }
      ]
    },
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "badge_text", "label": "Badge text", "default": "40% OFF", "info": "Leave blank to hide the badge" },
        { "type": "text", "id": "promo_code", "label": "Promo code", "info": "Leave blank to hide the promo line" }
      ]
    }
  ],
  "presets": [
    {
      "name": "For You product grid",
      "blocks": [
        { "type": "pill", "settings": { "label": "For You", "active": true } },
        { "type": "pill", "settings": { "label": "New In" } },
        { "type": "pill", "settings": { "label": "Sale" } },
        { "type": "pill", "settings": { "label": "Dresses" } },
        { "type": "pill", "settings": { "label": "Jeans" } },
        { "type": "pill", "settings": { "label": "Sets" } },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}

{{ 'for-you-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign pill_blocks = section.blocks | where: "type", "pill"
  assign card_blocks = section.blocks | where: "type", "product_card"
-%}

<section class="fn-section" id="fn-section-{{ section.id }}">

  {%- if section.settings.show_pills and pill_blocks.size > 0 -%}
  <div class="fn-filters">
    {%- for block in pill_blocks -%}
      <a
        href="{{ block.settings.link | default: '#' }}"
        class="fn-pill{% if block.settings.active %} active{% endif %}"
        {{ block.shopify_attributes }}
      >
        {%- if forloop.first -%}
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l1.9 5.8L20 9.7l-5 3.6 1.9 6.1L12 16.1l-4.9 3.3 1.9-6.1-5-3.6 6.1-1.9L12 2z"/>
          </svg>
        {%- endif -%}
        {{ block.settings.label }}
      </a>
    {%- endfor -%}
  </div>
  {%- endif -%}

  <div class="fn-grid">
    {%- for block in card_blocks -%}
      {%- assign product = block.settings.product -%}

      {%- if product and product != blank -%}
        <article class="fn-card" {{ block.shopify_attributes }}>

          <a href="{{ product.url }}" class="fn-media">
            {%- if product.featured_image -%}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
                loading="lazy"
                width="600"
                height="800"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'fn-media-placeholder' }}
            {%- endif -%}

            {%- if block.settings.badge_text != blank -%}
              <span class="fn-badge">{{ block.settings.badge_text }}</span>
            {%- endif -%}
          </a>

          <div class="fn-info">
            <div class="fn-title-row">
              <a href="{{ product.url }}" class="fn-title">{{ product.title }}</a>
              <button
                type="button"
                class="fn-heart"
                data-product-id="{{ product.id }}"
                aria-label="Add {{ product.title | escape }} to wishlist"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path d="M12 20.5s-7.5-4.6-10-9.4C0.3 7.8 2 4 5.6 4c2.1 0 3.6 1.2 4.4 2.6C10.8 5.2 12.3 4 14.4 4 18 4 19.7 7.8 18 11.1 15.5 15.9 12 20.5 12 20.5z"/>
                </svg>
              </button>
            </div>

            <div class="fn-price-row">
              <span class="fn-price">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="fn-price-original">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>

            {%- if block.settings.promo_code != blank -%}
              <div class="fn-promo">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20 10.5V4h-6.5L3 14.5 9.5 21 20 10.5zM7.3 9a1.3 1.3 0 1 1 0-2.6A1.3 1.3 0 0 1 7.3 9z"/>
                </svg>
                With Code: {{ block.settings.promo_code }}
              </div>
            {%- endif -%}

            {%- for option in product.options_with_values -%}
              {%- if option.name == 'Color' or option.name == 'Colour' -%}
                <div class="fn-swatches">
                  {%- for value in option.values limit: 4 -%}
                    <span
                      class="fn-swatch{% if forloop.first %} selected{% endif %}"
                      data-color-name="{{ value | handle }}"
                      title="{{ value }}"
                    ></span>
                  {%- endfor -%}
                  {%- if option.values.size > 4 -%}
                    <span class="fn-swatch-more">+{{ option.values.size | minus: 4 }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </article>

      {%- elsif request.design_mode -%}
        <article class="fn-card fn-card--empty" {{ block.shopify_attributes }}>
          <div class="fn-media fn-media--empty">
            <p>Select a product for this card</p>
          </div>
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>

</section>

<script src="{{ 'for-you-grid.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "For You product grid",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_pills",
      "label": "Show filter pills",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Filter pill",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "New In"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Usually a collection page"
        },
        {
          "type": "checkbox",
          "id": "active",
          "label": "Active by default",
          "default": false
        }
      ]
    },
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text",
          "default": "40% OFF",
          "info": "Leave blank to hide the badge"
        },
        {
          "type": "text",
          "id": "promo_code",
          "label": "Promo code",
          "info": "Leave blank to hide the promo line"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "For You product grid",
      "blocks": [
        { "type": "pill", "settings": { "label": "For You", "active": true } },
        { "type": "pill", "settings": { "label": "New In" } },
        { "type": "pill", "settings": { "label": "Sale" } },
        { "type": "pill", "settings": { "label": "Dresses" } },
        { "type": "pill", "settings": { "label": "Jeans" } },
        { "type": "pill", "settings": { "label": "Sets" } },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
